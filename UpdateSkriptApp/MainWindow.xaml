<Window x:Class="UpdateSkriptApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="UpdateSkript Deployment Tool" Height="600" Width="900"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- System Info -->
            <RowDefinition Height="*"/>    <!-- Log Area -->
            <RowDefinition Height="Auto"/> <!-- Progress -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="WINDOWS & DRIVER DEPLOYMENT" FontSize="24" FontWeight="Bold" Foreground="#007ACC"/>
            <Separator Background="#333" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- System Info -->
        <Border Grid.Row="1" Background="#2D2D30" CornerRadius="5" Padding="15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="System Model:" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{Binding SystemModel, FallbackValue='Detecting...'}" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Manufacturer:" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{Binding Manufacturer, FallbackValue='Detecting...'}" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log Area -->
        <Border Grid.Row="2" Background="Black" CornerRadius="5" Padding="5">
            <ScrollViewer x:Name="LogScrollViewer">
                <TextBox Text="{Binding LogOutput}" 
                         Background="Transparent" 
                         Foreground="#DCDCDC" 
                         BorderThickness="0" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         FontFamily="Consolas" 
                         FontSize="12"/>
            </ScrollViewer>
        </Border>

        <!-- Progress -->
        <StackPanel Grid.Row="3" Margin="0,20,0,10">
            <Grid>
                <TextBlock Text="{Binding CurrentAction, FallbackValue='Ready to start'}" HorizontalAlignment="Left" Foreground="Gray"/>
                <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0}%}" HorizontalAlignment="Right" Foreground="#007ACC"/>
            </Grid>
            <ProgressBar Value="{Binding ProgressPercentage}" Height="10" Margin="0,5,0,0" 
                         Background="#333" Foreground="#007ACC" BorderThickness="0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Reinstall" Command="{Binding ReinstallCommand}" Width="100" Height="35" Margin="0,0,10,0" Background="#3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="Start Update" Command="{Binding StartCommand}" Width="150" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
